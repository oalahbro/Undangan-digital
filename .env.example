PORT=3000

# Produksi (skema subdomain): domain dasar. Subdomain di bawahnya = slug client,
# mis. eka-salsa.undanganku.com → client "eka-salsa". Kosongkan untuk dev/Funnel.
BASE_DOMAIN=

# Super-admin panel (kelola semua client via web, tanpa CLI).
# SUPERADMIN_PATH  : path URL yang disamarkan, mis. /mgmt-a1b2c3 (jangan /admin atau /superadmin)
# SUPERADMIN_PASS  : password login panel. Kosongkan untuk menonaktifkan panel.
SUPERADMIN_PATH=/mgmt-x7k2
SUPERADMIN_PASS=

# Catatan: admin per-client memakai registry data/tenants.json (password di-hash),
# bukan lagi ADMIN_USER/ADMIN_PASS. Kelola via: node scripts/tenant.js
